{
  "name": "binary-2048",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "clean:next": "rm -rf .next .next-dev .next-build",
    "clean:dev": "rm -rf .next .next-dev .next-dev-*",
    "clean:build": "rm -rf .next .next-build",
    "predev": "npm run clean:dev",
    "dev": "bash ./scripts/dev-loop.sh",
    "dev:once": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-dev} NEXT_DISABLE_WEBPACK_CACHE=1 next dev",
    "dev:turbo": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-dev} NEXT_DISABLE_WEBPACK_CACHE=1 next dev --turbo",
    "prebuild": "npm run clean:build",
    "build": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next} next build && bash ./scripts/build-smoke.sh",
    "start": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next} next start",
    "test:unit": "jest --runInBand",
    "verify": "npm run test:unit && npm run build",
    "test:all": "npm run test:unit && npm run lint:warn && npm run spell:warn && npm run test:dev && npm run build",
    "test:routes": "npm run build",
    "test:dev": "bash ./scripts/dev-smoke.sh",
    "smoke:auth-proof": "bash ./scripts/auth-proof-smoke.sh",
    "bot:smoke": "node ./scripts/bot-smoke.mjs",
    "bot:smoke:dev": "bash ./scripts/bot-smoke-dev.sh",
    "bot:tourney": "node ./scripts/bot-tournament.mjs",
    "bot:benchmark": "node ./scripts/bot-benchmark.mjs",
    "league:sandbox:sim": "node ./scripts/league-sandbox-sim.mjs",
    "bot:tourney:dev": "bash ./scripts/bot-tournament-dev.sh",
    "mongo:smoke": "node ./scripts/mongo-smoke.mjs",
    "ops:amplify:watch": "bash ./scripts/amplify-deploy-watch.sh",
    "runs:export:dataset": "node ./scripts/export-runs-dataset.mjs",
    "runs:extract:features": "node ./scripts/extract-ml-features.mjs",
    "replay:ingest:worker": "node ./scripts/replay-ingest-worker.mjs",
    "ml:baseline": "node ./scripts/ml-baseline.mjs",
    "ops:waf:setup": "bash ./scripts/waf-setup.sh",
    "ops:waf:discover": "bash ./scripts/waf-discover.sh",
    "ops:waf:smoke": "bash ./scripts/waf-smoke.sh",
    "ops:waf:doctor": "bash ./scripts/waf-doctor.sh",
    "ops:waf:status": "bash ./scripts/waf-status.sh",
    "ops:waf:export": "bash ./scripts/waf-export.sh",
    "ops:waf:check": "bash ./scripts/waf-check.sh",
    "ops:waf:verify": "bash ./scripts/waf-verify.sh",
    "ops:waf:rollback": "bash ./scripts/waf-rollback.sh",
    "ops:waf:alarm": "bash ./scripts/waf-create-alarm.sh",
    "ops:waf:nxdomain": "bash ./scripts/waf-route53-nxdomain.sh",
    "ops:waf:budget": "bash ./scripts/waf-budget.sh",
    "ops:waf:sns": "bash ./scripts/waf-sns.sh",
    "ops:waf:tripwire-check": "bash ./scripts/waf-tripwire-check.sh",
    "ops:waf:tripwire-validate": "bash ./scripts/waf-tripwire-validate.sh",
    "ops:prod:smoke": "bash ./scripts/prod-smoke.sh",
    "ops:prod:verify": "bash ./scripts/post-deploy-verify.sh",
    "ops:prod:storage-rollout": "bash ./scripts/prod-storage-rollout.sh",
    "ops:prod:fingerprints": "bash ./scripts/prod-digest-fingerprints.sh",
    "ops:release:auth-check": "bash ./scripts/release-auth-check.sh",
    "ops:auth:amplify-fix": "bash ./scripts/auth-amplify-fix.sh",
    "ops:iam:amplify-ssm-check": "bash ./scripts/iam-amplify-ssm-check.sh",
    "ops:incident:bundle": "bash ./scripts/incident-evidence-bundle.sh",
    "ops:prod:browser": "playwright test -c playwright.prod.config.ts",
    "ops:prod:regional": "bash ./scripts/prod-regional-check.sh",
    "ops:prod:admin-token:sync": "bash ./scripts/prod-admin-token-sync.sh",
    "ops:prod:storage-check": "bash ./scripts/prod-storage-check.sh",
    "ops:prod:storage-check:amplify": "bash ./scripts/prod-storage-check-amplify.sh",
    "ops:egress:readiness": "bash ./scripts/fixed-egress-readiness.sh",
    "ops:egress:preflight": "bash ./scripts/fixed-egress-preflight.sh",
    "load:baseline": "k6 run ./scripts/load/k6-baseline.js",
    "load:ramp": "k6 run ./scripts/load/k6-ramp.js",
    "load:spike": "k6 run ./scripts/load/k6-spike.js",
    "load:soak": "k6 run ./scripts/load/k6-soak.js",
    "load:stage:gameplay": "node ./scripts/load/staged-gameplay.mjs",
    "load:stage:abuse": "node ./scripts/load/staged-heavy-abuse.mjs",
    "roadmap:status": "node ./scripts/roadmap-progress.mjs",
    "lint": "next lint",
    "lint:warn": "next lint || true",
    "spell:warn": "cspell \"README.md\" \"app/**/*.{ts,tsx}\" \"lib/**/*.ts\" \"scripts/**/*.{sh,mjs,md}\" \"docs/**/*.md\" --config cspell.json --no-progress || true",
    "curl:local": "BASE=http://localhost:3000; RESP=$(curl -sS -X POST \"$BASE/api/games\" -H \"Content-Type: application/json\" -d '{}'); echo \"$RESP\"; if command -v jq >/dev/null 2>&1; then ID=$(echo \"$RESP\" | jq -r '.id'); else ID=$(echo \"$RESP\" | sed -n 's/.*\"id\":\"\\([^\"]*\\)\".*/\\1/p'); fi; echo \"id=$ID\"; curl -sS \"$BASE/api/games/$ID/export\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "mongodb": "^6.20.0",
    "next": "15.5.12",
    "next-auth": "^4.24.13",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "cspell": "8.19.4",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.12",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "5.8.2"
  }
}
