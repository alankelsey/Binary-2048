# Required for production-mode auth routes (next start / Amplify SSR)
AUTH_SECRET=replace-with-a-long-random-secret

# Optional OAuth providers (needed for interactive sign-in)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional local URL hint for auth callbacks
NEXTAUTH_URL=http://localhost:3000
