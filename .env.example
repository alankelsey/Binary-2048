# Required for production-mode auth routes (next start / Amplify SSR)
AUTH_SECRET=replace-with-a-long-random-secret

# Optional OAuth providers (needed for interactive sign-in)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional local URL hint for auth callbacks
NEXTAUTH_URL=http://localhost:3000

# Optional replay artifact offload (for mongo run store)
# Set BINARY2048_RUN_STORE=mongo to use persistent run store.
BINARY2048_RUN_STORE=memory
BINARY2048_SESSION_STORE=memory
BINARY2048_REPLAY_ARTIFACT_STORE=inline
BINARY2048_REPLAY_S3_BUCKET=
BINARY2048_REPLAY_S3_REGION=us-east-2
BINARY2048_REPLAY_S3_PREFIX=replays
BINARY2048_REPLAY_S3_MIN_SCORE=2048
BINARY2048_REPLAY_S3_CONTEST_ONLY=false
BINARY2048_MONGO_SESSION_COLLECTION=sessions

# Optional sandbox/league test controls
BINARY2048_ADMIN_TOKEN=
BINARY2048_LEAGUE_SHADOW_WRITE=false
BINARY2048_SANDBOX_API_KEYS=
BINARY2048_SANDBOX_RATE_LIMIT_PER_5M=120

# Optional ops storage verification
# Used by /api/ops/storage/health and scripts/prod-storage-check.sh
BINARY2048_ADMIN_TOKEN=replace-me
